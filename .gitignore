# ============================================
# Python
# ============================================
__pycache__/
*.py[cod]
*.so
.pytest_cache/
*.egg-info/

# ============================================
# 环境
# ============================================
.vscode/
.idea/
*.swp

# ============================================
# 数据和输出（核心）
# ============================================
# 忽略所有输入数据
data/
# 例外：保留示例数据（如果你想添加）
# !data/example/
# !data/example/**

# 忽略所有运行输出
runs/

# 忽略 COLMAP 数据库
*.db
*.db-shm
*.db-wal

# ============================================
# COLMAP 输出文件
# ============================================
# 大文件格式
*.bin
runs/**/*.ply          # 只忽略 runs 下的点云
runs/**/*.log          # 只忽略 runs 下的日志

# ============================================
# 大文件
# ============================================
*.mp4
*.avi
*.mov
*.zip
*.tar.gz

# ============================================
# 临时文件和 OS
# ============================================
*.tmp
*.bak
.DS_Store
Thumbs.db

# ============================================
# 可选：Jupyter（如果想提交 notebook 就注释掉）
# ============================================
.ipynb_checkpoints
# *.ipynb  # 取消注释如果不想提交 notebook